# ==============================================
# Copy this file to ".env" and fill in real values.
#   cp .env.example .env      (or copy on Windows)
# The real ".env" is git-ignored and never committed.
# ==============================================

# --- SQL Server SA password (used by docker-compose and the API) ---
MSSQL_SA_PASSWORD=ChangeMe_StrongPassword123

# --- API: EF Core connection string (maps to ConnectionStrings:Default) ---
ConnectionStrings__Default=Server=localhost,1433;Database=LoginAnomalyDb;User Id=sa;Password=ChangeMe_StrongPassword123;TrustServerCertificate=True;

# --- API: JWT signing key, base64 recommended (maps to Jwt:Key) ---
Jwt__Key=replace-with-your-own-long-random-secret
